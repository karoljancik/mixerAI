@{
    ViewData["Title"] = "Registrácia";
}

<div class="row justify-content-center">
    <div class="col-md-5 mt-5">
        <div class="hero-panel text-center">
            <div class="hero-copy mb-4">
                <h2>Vytvor si účet</h2>
                <p>Pripoj sa a ukladaj si svoje vygenerované diela natrvalo.</p>
            </div>
        </div>

        <div class="mix-form-panel">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" style="background: rgba(255, 122, 24, 0.1); border-color: rgba(255, 122, 24, 0.3); color: var(--accent);">
                    @Html.ValidationSummary(false)
                </div>
            }

            <form asp-controller="Account" asp-action="Register" method="post">
                <div class="mb-4">
                    <label class="eyebrow mb-2">Email</label>
                    <input type="email" name="email" class="form-control" required placeholder="dj@beatmix.app"/>
                </div>
                
                <div class="mb-4">
                    <label class="eyebrow mb-2">Bezpečné Heslo</label>
                    <input type="password" name="password" class="form-control" required placeholder="Minimálne 6 znakov a 1 číslo"/>
                </div>
                
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-accent fs-5">Zaregistrovať profil</button>
                </div>
                
                <div class="text-center mt-4">
                    <span class="text-muted">Už máš svoj účet?</span> <a asp-action="Login" style="color: var(--accent); font-weight: bold; margin-left:8px;">Prihlás sa tu</a>
                </div>
            </form>
        </div>
    </div>
</div>
