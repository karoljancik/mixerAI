@model MixerAI.Web.Models.StudioWorkspaceViewModel
@{
    ViewData["Title"] = "AI DJ Producer Workspace";
    Layout = "_StudioLayout";
}

<section class="workspace-hero">
    <div>
        <p class="workspace-kicker">MixerAI Workspace</p>
        <h1>AI-powered DJ and producer copilot</h1>
        <p class="workspace-copy">
            Build transitions, discover set matches, and generate fresh sketches for young DJs and producers in one flow.
        </p>
    </div>
    <div class="workspace-metrics">
        <div class="workspace-metric">
            <span class="workspace-metric-label">Ready tracks</span>
            <strong>@Model.ReadyTrackCount</strong>
        </div>
        <div class="workspace-metric">
            <span class="workspace-metric-label">Needs attention</span>
            <strong>@Model.FailedTrackCount</strong>
        </div>
        <div class="workspace-metric">
            <span class="workspace-metric-label">AI set corpus</span>
            <strong>@Model.AvailableSetIds.Count</strong>
        </div>
    </div>
</section>

<div class="studio-waveform-bar">
    <div class="waveform-track deck-a-color" id="drop-zone-a"
         ondragover="event.preventDefault(); this.classList.add('drop-hover-a')"
         ondragleave="this.classList.remove('drop-hover-a')"
         ondrop="handleDrop(event, 'a')">
        <div class="waveform-label">DECK A</div>
        <div id="waveform-a-full" class="waveform-full"></div>
    </div>
    <div class="waveform-track deck-b-color" id="drop-zone-b"
         ondragover="event.preventDefault(); this.classList.add('drop-hover-b')"
         ondragleave="this.classList.remove('drop-hover-b')"
         ondrop="handleDrop(event, 'b')">
        <div class="waveform-label">DECK B</div>
        <div id="waveform-b-full" class="waveform-full"></div>
    </div>
</div>

<div class="studio-main">
    <div class="deck-unit deck-a-unit"
         ondragover="event.preventDefault(); this.style.boxShadow='0 0 0 2px var(--deck-a)'"
         ondragleave="this.style.boxShadow=''"
         ondrop="handleDrop(event, 'a'); this.style.boxShadow=''">
        <div class="deck-body">
            <div class="deck-meta">
                <div class="track-name" id="title-a">No Track Loaded</div>
                <div class="track-sub">
                    <span class="meta-bpm" id="bpm-a">--- BPM</span>
                    <span class="camelot-badge" id="key-a">--</span>
                </div>
                <div id="time-a" class="deck-time">0:00</div>
            </div>
            <div class="vinyl-disc" id="vinyl-a">
                <div class="vinyl-inner" id="vinyl-icon-a">&#9654;</div>
            </div>
        </div>
        <div class="deck-controls-bar">
            <button class="ctrl-btn" onclick="wavesurferA.skip(-5)" title="-5s">&#9198;</button>
            <button class="ctrl-btn play-btn" id="btn-play-a" onclick="togglePlay('a')" title="Play/Pause">&#9654;</button>
            <button class="ctrl-btn" onclick="wavesurferA.stop()" title="Stop">&#9632;</button>
        </div>
    </div>

    <div class="mixer-center">
        <div class="mixer-label">Transition Coach</div>
        <div class="crossfader-container" title="Preview crossfader for live deck playback only. It does not affect the generated mix.">
            <div class="crossfader-label">CF</div>
            <input type="range" id="crossfader" min="0" max="100" value="50" class="crossfader-slider" oninput="updateCrossfade(this.value)" />
        </div>
        <div class="ai-copilot" id="ai-advice">
            <div class="ai-copilot-header">AI TRANSITION COACH</div>
            <div id="advice-text" class="ai-advice-text">Load both decks to get BPM, key and transition guidance.</div>
        </div>
        <button id="render-btn" class="render-btn" onclick="renderMix()">
            <span id="render-btn-text">Generate AI Mix</span>
        </button>
        <div id="render-result" class="render-result" style="display:none;"></div>
    </div>

    <div class="deck-unit deck-b-unit"
         ondragover="event.preventDefault(); this.style.boxShadow='0 0 0 2px var(--deck-b)'"
         ondragleave="this.style.boxShadow=''"
         ondrop="handleDrop(event, 'b'); this.style.boxShadow=''">
        <div class="deck-body">
            <div class="deck-meta">
                <div class="track-name" id="title-b">No Track Loaded</div>
                <div class="track-sub">
                    <span class="meta-bpm" id="bpm-b">--- BPM</span>
                    <span class="camelot-badge camelot-b" id="key-b">--</span>
                </div>
                <div id="time-b" class="deck-time">0:00</div>
            </div>
            <div class="vinyl-disc vinyl-b" id="vinyl-b">
                <div class="vinyl-inner" id="vinyl-icon-b">&#9654;</div>
            </div>
        </div>
        <div class="deck-controls-bar">
            <button class="ctrl-btn" onclick="wavesurferB.skip(-5)" title="-5s">&#9198;</button>
            <button class="ctrl-btn play-btn" id="btn-play-b" onclick="togglePlay('b')" title="Play/Pause">&#9654;</button>
            <button class="ctrl-btn" onclick="wavesurferB.stop()" title="Stop">&#9632;</button>
        </div>
    </div>
</div>

<section class="ai-workbench-grid">
    <article class="ai-panel">
        <div class="ai-panel-header">
            <div>
                <p class="ai-panel-kicker">AI Matchmaker</p>
                <h2>Find transition-ready sets</h2>
            </div>
            <span class="ai-panel-badge">@Model.AvailableSetIds.Count data sets</span>
        </div>

        @if (Model.AvailableSetIds.Count == 0)
        {
            <p class="ai-empty-state">Import feature manifests into the corpus first. Once present, the copilot can rank transition candidates across sets.</p>
        }
        else
        {
            <form asp-action="RecommendTransitions" method="post" class="ai-form-grid">
                <div class="ai-form-field">
                    <label asp-for="Recommendation.LeftSetId"></label>
                    <select asp-for="Recommendation.LeftSetId" class="studio-select">
                        @foreach (var setId in Model.AvailableSetIds)
                        {
                            <option value="@setId">@setId</option>
                        }
                    </select>
                    <span asp-validation-for="Recommendation.LeftSetId" class="text-danger"></span>
                </div>
                <div class="ai-form-field">
                    <label asp-for="Recommendation.RightSetId"></label>
                    <select asp-for="Recommendation.RightSetId" class="studio-select">
                        @foreach (var setId in Model.AvailableSetIds)
                        {
                            <option value="@setId">@setId</option>
                        }
                    </select>
                    <span asp-validation-for="Recommendation.RightSetId" class="text-danger"></span>
                </div>
                <div class="ai-form-field">
                    <label asp-for="Recommendation.TopK"></label>
                    <input asp-for="Recommendation.TopK" class="studio-input" min="1" max="20" />
                    <span asp-validation-for="Recommendation.TopK" class="text-danger"></span>
                </div>
                <div class="ai-form-actions">
                    <button type="submit" class="studio-secondary-btn">Recommend Transitions</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.RecommendationErrorMessage))
            {
                <div class="inline-error-card">@Model.RecommendationErrorMessage</div>
            }

            @if (Model.RecommendationResults.Any())
            {
                <div class="recommendation-list">
                    @foreach (var recommendation in Model.RecommendationResults)
                    {
                        <div class="recommendation-item">
                            <div class="recommendation-meta">
                                <strong>@recommendation.LeftSetId</strong>
                                <span>@recommendation.LeftStartSeconds.ToString("0.0")s</span>
                            </div>
                            <div class="recommendation-arrow">&#8594;</div>
                            <div class="recommendation-meta">
                                <strong>@recommendation.RightSetId</strong>
                                <span>@recommendation.RightStartSeconds.ToString("0.0")s</span>
                            </div>
                            <div class="recommendation-score">
                                <span>Fit score</span>
                                <strong>@((recommendation.Probability * 100).ToString("0.0"))%</strong>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </article>

    <article class="ai-panel">
        <div class="ai-panel-header">
            <div>
                <p class="ai-panel-kicker">Producer Lab</p>
                <h2>Generate track sketches</h2>
            </div>
            <span class="ai-panel-badge">Phrase and latent models</span>
        </div>

        <form asp-action="GenerateTrack" method="post" class="ai-form-grid">
            <div class="ai-form-field">
                <label asp-for="Generation.GeneratedTrackStyle"></label>
                <select asp-for="Generation.GeneratedTrackStyle" class="studio-select">
                    <option value="liquid">Liquid</option>
                    <option value="deep">Deep</option>
                </select>
                <span asp-validation-for="Generation.GeneratedTrackStyle" class="text-danger"></span>
            </div>
            <div class="ai-form-field">
                <label asp-for="Generation.GeneratedTrackDurationSeconds"></label>
                <input asp-for="Generation.GeneratedTrackDurationSeconds" class="studio-input" min="96" max="240" />
                <span asp-validation-for="Generation.GeneratedTrackDurationSeconds" class="text-danger"></span>
            </div>
            <div class="ai-form-field">
                <label asp-for="Generation.GeneratedTrackSeed"></label>
                <input asp-for="Generation.GeneratedTrackSeed" class="studio-input" placeholder="Optional seed" />
                <span asp-validation-for="Generation.GeneratedTrackSeed" class="text-danger"></span>
            </div>
            <div class="ai-form-actions">
                <button type="submit" class="studio-secondary-btn">Generate Sketch</button>
            </div>
        </form>

        <form asp-action="GenerateMiniMix" method="post" class="ai-inline-form">
            <input type="hidden" asp-for="Generation.GeneratedTrackStyle" />
            <input type="hidden" asp-for="Generation.GeneratedTrackDurationSeconds" />
            <input type="hidden" asp-for="Generation.GeneratedTrackSeed" />
            <button type="submit" class="studio-ghost-btn">Generate Mini Mix Inspiration</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.GenerationErrorMessage))
        {
            <div class="inline-error-card">@Model.GenerationErrorMessage</div>
        }

        <div class="ai-panel-note">
            Use the generated sketch as a starting point for arrangement ideas, transitions, and groove experiments, not as a final master.
        </div>
    </article>

    <article class="ai-panel">
        <div class="ai-panel-header">
            <div>
                <p class="ai-panel-kicker">Learning Loop</p>
                <h2>What the copilot is helping with</h2>
            </div>
            <span class="ai-panel-badge">Human-in-the-loop</span>
        </div>
        <ul class="ai-insight-list">
            <li>Tempo compatibility and key awareness for each deck pairing.</li>
            <li>Corpus-backed transition recommendations from real set features.</li>
            <li>Fast generative sketches to unblock beginner producers creatively.</li>
            <li>Failure recovery for track analysis with visible retry actions.</li>
        </ul>
    </article>
</section>

<div class="studio-library">
    <div class="library-header">
        <span class="eyebrow">LIBRARY - drag a ready track onto a deck</span>
        <a href="/Library" class="library-manage-btn">Manage Library</a>
    </div>
    <div class="library-table-wrap">
        <table class="library-table">
            <thead>
                <tr>
                    <th style="width:110px">Status</th>
                    <th>Title</th>
                    <th style="width:70px">BPM</th>
                    <th style="width:60px">Key</th>
                    <th style="width:70px">Length</th>
                    <th style="width:90px">Attempts</th>
                    <th style="width:150px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var track in Model.Tracks)
                {
                    var isReady = string.Equals(track.Status, "Ready", StringComparison.OrdinalIgnoreCase);
                    var isError = string.Equals(track.Status, "Error", StringComparison.OrdinalIgnoreCase);
                    <tr class="library-row @(!isReady ? "row-not-ready" : "")"
                        id="lib-row-@track.Id"
                        data-id="@track.Id"
                        data-bpm="@(track.BPM?.ToString("0.0") ?? "--")"
                        data-key="@(track.CamelotKey ?? "--")"
                        data-title="@track.Title"
                        data-waveform="@track.WaveformDataJson"
                        data-duration="@track.DurationSeconds"
                        draggable="@(isReady ? "true" : "false")"
                        ondragstart="handleDragStart(event, '@track.Id')"
                        ondragend="this.classList.remove('is-dragging')">
                        <td>
                            @if (isReady)
                            {
                                <span class="status-pill status-ready">Ready</span>
                            }
                            else if (string.Equals(track.Status, "Analyzing", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="status-pill status-analyzing"><span class="spinner-dot"></span> Analyzing</span>
                            }
                            else if (isError)
                            {
                                <span class="status-pill status-error">Error</span>
                            }
                            else
                            {
                                <span class="status-pill status-pending">Queued</span>
                            }
                        </td>
                        <td class="lib-title" title="@track.Title">
                            <div>@track.Title</div>
                            @if (isError && !string.IsNullOrWhiteSpace(track.LastAnalysisError))
                            {
                                <div class="track-inline-error">@track.LastAnalysisError</div>
                            }
                        </td>
                        <td class="lib-bpm">@(track.BPM?.ToString("0.0") ?? "--")</td>
                        <td><span class="camelot-badge-sm">@(track.CamelotKey ?? "--")</span></td>
                        <td class="lib-dur">@(track.DurationSeconds > 0 ? TimeSpan.FromSeconds(track.DurationSeconds).ToString(@"mm\:ss") : "--")</td>
                        <td class="lib-dur">@track.AnalysisAttempts</td>
                        <td>
                            <div class="library-actions">
                                @if (isReady)
                                {
                                    <div class="lib-load-btns">
                                        <button type="button" onclick="loadFromLib('a', '@track.Id')" class="lib-btn lib-btn-a" title="Load to A">A</button>
                                        <button type="button" onclick="loadFromLib('b', '@track.Id')" class="lib-btn lib-btn-b" title="Load to B">B</button>
                                    </div>
                                }
                                else if (isError)
                                {
                                    <button type="button" class="mini-action-btn" onclick="retryTrackAnalysis('@track.Id', '@track.Title')">Retry</button>
                                }

                                <button type="button" class="lib-delete-btn-mini" onclick="deleteTrackFromMini('@track.Id', '@track.Title')">&#128465;</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Tracks.Any())
                {
                    <tr><td colspan="7" class="lib-empty">Upload your first track in <a href="/Library">Library</a> to start mixing.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<style>
.drop-hover-a { background: var(--deck-a-dim) !important; outline: 2px dashed var(--deck-a); }
.drop-hover-b { background: var(--deck-b-dim) !important; outline: 2px dashed var(--deck-b); }
.library-row[draggable=true] { cursor: grab; }
.library-row[draggable=true]:active { cursor: grabbing; }
</style>
<script src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
<script>
const wsBaseConfig = {
    height: 70,
    barWidth: 2,
    barGap: 1,
    barRadius: 1,
    normalize: true,
    interact: true,
    minPxPerSec: 50,
    hideScrollbar: true,
    cursorWidth: 2,
    cursorColor: '#fff',
};

function buildDeckWaveConfig(deck) {
    if (deck === 'a') {
        return {
            waveColor: 'rgba(255, 122, 24, 0.38)',
            progressColor: '#ff7a18',
        };
    }

    return {
        waveColor: 'rgba(78, 159, 255, 0.38)',
        progressColor: '#4e9fff',
    };
}

const wavesurferA = WaveSurfer.create({
    ...wsBaseConfig,
    container: '#waveform-a-full',
    ...buildDeckWaveConfig('a'),
});

const wavesurferB = WaveSurfer.create({
    ...wsBaseConfig,
    container: '#waveform-b-full',
    ...buildDeckWaveConfig('b'),
});

let stateA = { id: null, playing: false, bpm: null, key: null };
let stateB = { id: null, playing: false, bpm: null, key: null };
let vinylAngleA = 0;
let vinylAngleB = 0;

function animateVinyls() {
    if (stateA.playing) {
        vinylAngleA += 2.0;
        document.getElementById('vinyl-a').style.transform = `rotate(${vinylAngleA}deg)`;
    }
    if (stateB.playing) {
        vinylAngleB += 2.0;
        document.getElementById('vinyl-b').style.transform = `rotate(${vinylAngleB}deg)`;
    }
    requestAnimationFrame(animateVinyls);
}
requestAnimationFrame(animateVinyls);

[[wavesurferA, 'a'], [wavesurferB, 'b']].forEach(([ws, deck]) => {
    ws.on('timeupdate', time => { document.getElementById(`time-${deck}`).textContent = formatTime(time); });
    ws.on('play', () => {
        if (deck === 'a') stateA.playing = true; else stateB.playing = true;
        updatePlayBtn(deck, true);
    });
    ws.on('pause', () => {
        if (deck === 'a') stateA.playing = false; else stateB.playing = false;
        updatePlayBtn(deck, false);
    });
    ws.on('finish', () => {
        if (deck === 'a') stateA.playing = false; else stateB.playing = false;
        updatePlayBtn(deck, false);
    });
    ws.on('error', error => {
        console.error(`WaveSurfer error for deck ${deck.toUpperCase()}:`, error);
        document.getElementById(`title-${deck}`).innerHTML = '<span style="color:var(--danger)">Audio file not available</span>';
    });
});

function updatePlayBtn(deck, playing) {
    document.getElementById(`btn-play-${deck}`).textContent = playing ? '\u23f8' : '\u25b6';
    document.getElementById(`vinyl-icon-${deck}`).textContent = playing ? '\u23f8' : '\u25b6';
}

function formatTime(seconds) {
    return `${Math.floor(seconds / 60)}:${Math.floor(seconds % 60).toString().padStart(2, '0')}`;
}

function loadTrack(deck, trackId) {
    if (!trackId) return;

    const row = document.querySelector(`.library-row[data-id="${trackId}"]`);
    if (!row) return;

    const bpm = row.dataset.bpm;
    const key = row.dataset.key;
    const title = row.dataset.title;
    const waveformRaw = row.dataset.waveform;
    const duration = row.dataset.duration;

    if (deck === 'a') {
        stateA.id = trackId;
        stateA.bpm = parseFloat(bpm);
        stateA.key = key;
    } else {
        stateB.id = trackId;
        stateB.bpm = parseFloat(bpm);
        stateB.key = key;
    }

    document.getElementById(`title-${deck}`).textContent = title || 'Unknown';
    document.getElementById(`bpm-${deck}`).textContent = `${bpm} BPM`;
    document.getElementById(`key-${deck}`).textContent = key || '--';

    document.querySelectorAll('.library-row').forEach(rowElement => rowElement.classList.remove(`active-${deck}`));
    row.classList.add(`active-${deck}`);

    const ws = deck === 'a' ? wavesurferA : wavesurferB;
    const audioUrl = `/Library/audio/${trackId}?v=${Date.now()}`;

    let peaks = null;
    try {
        if (waveformRaw && waveformRaw.length > 2) {
            peaks = JSON.parse(waveformRaw);
        }
    } catch (error) {
        console.warn('Failed to parse waveform peaks.', error);
    }

    if (peaks && peaks.length > 0 && duration && parseFloat(duration) > 0) {
        ws.load(audioUrl, peaks, parseFloat(duration));
    } else {
        ws.load(audioUrl);
    }

    updateAiAdvice();
}

function loadFromLib(deck, trackId) {
    loadTrack(deck, trackId);
}

function handleDragStart(event, trackId) {
    event.currentTarget.classList.add('is-dragging');
    event.dataTransfer.effectAllowed = 'copy';
    event.dataTransfer.setData('trackId', trackId);
}

function handleDrop(event, deck) {
    event.preventDefault();
    const id = event.dataTransfer.getData('trackId');
    document.getElementById(`drop-zone-${deck}`)?.classList.remove(`drop-hover-${deck}`);
    if (id) loadTrack(deck, id);
}

function togglePlay(deck) {
    (deck === 'a' ? wavesurferA : wavesurferB).playPause();
}

function updateCrossfade(value) {
    wavesurferA.setVolume((100 - value) / 100);
    wavesurferB.setVolume(value / 100);
}

function updateAiAdvice() {
    const advice = document.getElementById('advice-text');
    if (!stateA.id || !stateB.id) {
        advice.innerHTML = 'Load both tracks to get transition notes, BPM fit and tonal hints.';
        return;
    }

    const messages = [];
    if (!isNaN(stateA.bpm) && !isNaN(stateB.bpm)) {
        const diff = Math.abs(stateA.bpm - stateB.bpm).toFixed(1);
        if (diff <= 3) messages.push(`Tempo fit is strong: <b>${stateA.bpm}</b> vs <b>${stateB.bpm}</b> BPM.`);
        else if (diff <= 8) messages.push(`Tempo gap is ${diff} BPM. Light sync should still work.`);
        else messages.push(`Tempo gap is ${diff} BPM. Expect heavier stretching on deck B.`);
    }

    if (stateA.key && stateB.key && stateA.key !== '--' && stateB.key !== '--') {
        if (stateA.key === stateB.key) {
            messages.push(`Keys align cleanly in <b>${stateA.key}</b>.`);
        } else {
            messages.push(`Check harmonic blend: <b>${stateA.key}</b> into <b>${stateB.key}</b>.`);
        }
    }

    messages.push('Next step: render a reference mix, then compare it to your own manual transition.');
    advice.innerHTML = messages.join('<br>');
}

async function retryTrackAnalysis(id, title) {
    if (!confirm(`Retry analysis for "${title}"?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    try {
        const response = await fetch(`/Library/retry/${id}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token,
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ '__RequestVerificationToken': token }),
        });

        if (!response.ok) {
            alert('Retry request failed.');
            return;
        }

        window.location.reload();
    } catch (error) {
        alert(`Retry failed: ${error.message}`);
    }
}

async function deleteTrackFromMini(id, title) {
    if (!confirm(`Delete "${title}" from the library?`)) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    try {
        const response = await fetch(`/Library/delete/${id}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token,
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ '__RequestVerificationToken': token }),
        });
        if (!response.ok) {
            alert('Delete failed.');
            return;
        }

        const row = document.getElementById(`lib-row-${id}`);
        if (row) {
            row.style.transition = 'opacity 0.3s, transform 0.3s';
            row.style.opacity = '0';
            row.style.transform = 'translateX(-20px)';
            setTimeout(() => row.remove(), 300);
        }
    } catch (error) {
        alert(`Delete failed: ${error.message}`);
    }
}

async function renderMix() {
    if (!stateA.id || !stateB.id) {
        document.getElementById('advice-text').innerHTML = 'Choose tracks for both decks first.';
        return;
    }

    const btn = document.getElementById('render-btn');
    const btnText = document.getElementById('render-btn-text');
    const resultDiv = document.getElementById('render-result');
    btn.disabled = true;
    btnText.textContent = 'Rendering...';
    resultDiv.style.display = 'none';

    try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const formData = new FormData();
        formData.append('trackAId', stateA.id);
        formData.append('trackBId', stateB.id);
        formData.append('__RequestVerificationToken', token);

        const response = await fetch('/Home/RenderMix', { method: 'POST', body: formData });
        if (!response.ok) {
            throw new Error((await response.text()).substring(0, 220));
        }

        const blob = await response.blob();
        const url = URL.createObjectURL(blob);
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `
            <div class="render-success">
                AI mix reference ready.
                <audio controls src="${url}" class="render-audio"></audio>
                <a href="${url}" download="mixerai-mix.mp3">Download MP3</a>
            </div>`;
    } catch (error) {
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `<div class="render-error">${error.message}</div>`;
    } finally {
        btn.disabled = false;
        btnText.textContent = 'Generate AI Mix';
    }
}
</script>
<partial name="_ValidationScriptsPartial" />
}
