@model List<MixerAI.Web.Models.TrackViewModel>
@{
    ViewData["Title"] = "DJ Studio";
    Layout = "_StudioLayout";
}

<!-- WAVEFORM BAR - TOP - also acts as drop zones -->
<div class="studio-waveform-bar">
    <div class="waveform-track deck-a-color" id="drop-zone-a"
         ondragover="event.preventDefault(); this.classList.add('drop-hover-a')"
         ondragleave="this.classList.remove('drop-hover-a')"
         ondrop="handleDrop(event, 'a')">
        <div class="waveform-label">DECK A</div>
        <div id="waveform-a-full" class="waveform-full"></div>
    </div>
    <div class="waveform-track deck-b-color" id="drop-zone-b"
         ondragover="event.preventDefault(); this.classList.add('drop-hover-b')"
         ondragleave="this.classList.remove('drop-hover-b')"
         ondrop="handleDrop(event, 'b')">
        <div class="waveform-label">DECK B</div>
        <div id="waveform-b-full" class="waveform-full"></div>
    </div>
</div>

<!-- MAIN DECK AREA -->
<div class="studio-main">
    <!-- DECK A -->
    <div class="deck-unit deck-a-unit"
         ondragover="event.preventDefault(); this.style.boxShadow='0 0 0 2px var(--deck-a)'"
         ondragleave="this.style.boxShadow=''"
         ondrop="handleDrop(event, 'a'); this.style.boxShadow=''">
        <div class="track-selector-bar">
            <select id="select-track-a" onchange="loadTrack('a', this.value)" class="track-select">
                <option value="">─ Vyber / Pretiahni track ─</option>
                @foreach (var t in Model.Where(x => x.Status == "Ready"))
                {
                    <option value="@t.Id" data-bpm="@(t.BPM?.ToString("0.0") ?? "--")" data-key="@(t.CamelotKey ?? "--")" data-title="@t.Title" data-waveform="@t.WaveformDataJson" data-duration="@t.DurationSeconds">
                        @t.Title  (@(t.BPM?.ToString("0.0") ?? "--") BPM · @(t.CamelotKey ?? "--"))
                    </option>
                }
            </select>
        </div>
        <div class="deck-body">
            <div class="deck-meta">
                <div class="track-name" id="title-a">No Track Loaded</div>
                <div class="track-sub">
                    <span class="meta-bpm" id="bpm-a">--- BPM</span>
                    <span class="camelot-badge" id="key-a">--</span>
                </div>
                <div id="time-a" class="deck-time">0:00</div>
            </div>
            <div class="vinyl-disc" id="vinyl-a">
                <div class="vinyl-inner" id="vinyl-icon-a">▶</div>
            </div>
        </div>
        <div class="deck-controls-bar">
            <button class="ctrl-btn" onclick="wavesurferA.skip(-5)" title="–5s">⏮</button>
            <button class="ctrl-btn play-btn" id="btn-play-a" onclick="togglePlay('a')" title="Play/Pause">▶</button>
            <button class="ctrl-btn" onclick="wavesurferA.stop()" title="Stop">■</button>
        </div>
    </div>

    <!-- CENTER MIXER -->
    <div class="mixer-center">
        <div class="mixer-label">MIXER</div>
        <div class="crossfader-container">
            <div class="crossfader-label">CF</div>
            <input type="range" id="crossfader" min="0" max="100" value="50" class="crossfader-slider" oninput="updateCrossfade(this.value)" />
        </div>
        <div class="ai-copilot" id="ai-advice">
            <div class="ai-copilot-header">🤖 AI CO-PILOT</div>
            <div id="advice-text" class="ai-advice-text">Načítaj skladby do oboch deckov.</div>
        </div>
        <button id="render-btn" class="render-btn" onclick="renderMix()">
            <span id="render-btn-text">⚡ GENERATE MIX</span>
        </button>
        <div id="render-result" class="render-result" style="display:none;"></div>
    </div>

    <!-- DECK B -->
    <div class="deck-unit deck-b-unit"
         ondragover="event.preventDefault(); this.style.boxShadow='0 0 0 2px var(--deck-b)'"
         ondragleave="this.style.boxShadow=''"
         ondrop="handleDrop(event, 'b'); this.style.boxShadow=''">
        <div class="track-selector-bar">
            <select id="select-track-b" onchange="loadTrack('b', this.value)" class="track-select">
                <option value="">─ Vyber / Pretiahni track ─</option>
                @foreach (var t in Model.Where(x => x.Status == "Ready"))
                {
                    <option value="@t.Id" data-bpm="@(t.BPM?.ToString("0.0") ?? "--")" data-key="@(t.CamelotKey ?? "--")" data-title="@t.Title" data-waveform="@t.WaveformDataJson" data-duration="@t.DurationSeconds">
                        @t.Title  (@(t.BPM?.ToString("0.0") ?? "--") BPM · @(t.CamelotKey ?? "--"))
                    </option>
                }
            </select>
        </div>
        <div class="deck-body">
            <div class="deck-meta">
                <div class="track-name" id="title-b">No Track Loaded</div>
                <div class="track-sub">
                    <span class="meta-bpm" id="bpm-b">--- BPM</span>
                    <span class="camelot-badge camelot-b" id="key-b">--</span>
                </div>
                <div id="time-b" class="deck-time">0:00</div>
            </div>
            <div class="vinyl-disc vinyl-b" id="vinyl-b">
                <div class="vinyl-inner" id="vinyl-icon-b">▶</div>
            </div>
        </div>
        <div class="deck-controls-bar">
            <button class="ctrl-btn" onclick="wavesurferB.skip(-5)" title="–5s">⏮</button>
            <button class="ctrl-btn play-btn" id="btn-play-b" onclick="togglePlay('b')" title="Play/Pause">▶</button>
            <button class="ctrl-btn" onclick="wavesurferB.stop()" title="Stop">■</button>
        </div>
    </div>
</div>

<!-- TRACK LIBRARY (mini) -->
<div class="studio-library">
    <div class="library-header">
        <span class="eyebrow">📁 KNIŽNICA — pretiahni track na deck</span>
        <a href="/Library" class="library-manage-btn">SPRAVOVAŤ</a>
    </div>
    <div class="library-table-wrap">
        <table class="library-table">
            <thead>
                <tr>
                    <th style="width:70px">STATUS</th>
                    <th>Názov</th>
                    <th style="width:70px">BPM</th>
                    <th style="width:50px">KEY</th>
                    <th style="width:60px">Dĺžka</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    var isReady = t.Status == "Ready";
                    <tr class="library-row @(!isReady ? "row-not-ready" : "")"
                        id="lib-row-@t.Id"
                        data-id="@t.Id"
                        data-bpm="@(t.BPM?.ToString("0.0") ?? "--")"
                        data-key="@(t.CamelotKey ?? "--")"
                        data-title="@t.Title"
                        data-waveform="@t.WaveformDataJson"
                        data-duration="@t.DurationSeconds"
                        draggable="@(isReady ? "true" : "false")"
                        ondragstart="handleDragStart(event, '@t.Id')"
                        ondragend="this.classList.remove('is-dragging')">
                        <td>
                            @if (isReady)
                            {
                                <div class="lib-load-btns">
                                    <button onclick="loadFromLib('a', '@t.Id')" class="lib-btn lib-btn-a" title="Load to A">A</button>
                                    <button onclick="loadFromLib('b', '@t.Id')" class="lib-btn lib-btn-b" title="Load to B">B</button>
                                </div>
                            }
                            else if (t.Status == "Analyzing")
                            {
                                <span class="badge-analyzing"><span class="spinner-dot"></span></span>
                            }
                            else
                            {
                                <span class="badge-error" title="@t.Status">!</span>
                            }
                        </td>
                        <td class="lib-title" title="@t.Title">@t.Title</td>
                        <td class="lib-bpm">@(t.BPM?.ToString("0.0") ?? "--")</td>
                        <td><span class="camelot-badge-sm">@(t.CamelotKey ?? "--")</span></td>
                        <td class="lib-dur">@(t.DurationSeconds > 0 ? TimeSpan.FromSeconds(t.DurationSeconds).ToString(@"mm\:ss") : "--")</td>
                        <td>
                            <button class="lib-delete-btn-mini" onclick="deleteTrackFromMini('@t.Id', '@t.Title')">🗑</button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="lib-empty">Pridaj skladbu v sekcii <a href="/Library">Spravovať</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<style>
.drop-hover-a { background: var(--deck-a-dim) !important; outline: 2px dashed var(--deck-a); }
.drop-hover-b { background: var(--deck-b-dim) !important; outline: 2px dashed var(--deck-b); }
.library-row[draggable=true] { cursor: grab; }
.library-row[draggable=true]:active { cursor: grabbing; }
</style>
<script src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
<script>
// ════════════════════════════════════════
//  MixerAI PRO — Studio Engine v3 (Pro Clean)
// ════════════════════════════════════════

// ── Shared WaveSurfer Config ──
const wsBaseConfig = {
    height: 70,
    barWidth: 2,
    barGap: 1,
    barRadius: 1,
    normalize: true,
    interact: true,
    minPxPerSec: 50,
    hideScrollbar: true,
    cursorWidth: 2,
    cursorColor: '#fff',
};

function buildDeckWaveConfig(deck) {
    if (deck === 'a') {
        return {
            waveColor: 'rgba(255, 122, 24, 0.38)',
            progressColor: '#ff7a18',
        };
    }

    return {
        waveColor: 'rgba(78, 159, 255, 0.38)',
        progressColor: '#4e9fff',
    };
}

const wavesurferA = WaveSurfer.create({
    ...wsBaseConfig,
    container: '#waveform-a-full',
    ...buildDeckWaveConfig('a'),
});

const wavesurferB = WaveSurfer.create({
    ...wsBaseConfig,
    container: '#waveform-b-full',
    ...buildDeckWaveConfig('b'),
});

// ── State ──
let stateA = { id: null, playing: false, bpm: null, key: null };
let stateB = { id: null, playing: false, bpm: null, key: null };
let vinylAngleA = 0, vinylAngleB = 0;

// ── Vinyl spin ──
function animateVinyls() {
    if (stateA.playing) { vinylAngleA += 2.0; document.getElementById('vinyl-a').style.transform = `rotate(${vinylAngleA}deg)`; }
    if (stateB.playing) { vinylAngleB += 2.0; document.getElementById('vinyl-b').style.transform = `rotate(${vinylAngleB}deg)`; }
    requestAnimationFrame(animateVinyls);
}
requestAnimationFrame(animateVinyls);

// ── WaveSurfer events ──
[ [wavesurferA, 'a'], [wavesurferB, 'b'] ].forEach(([ws, d]) => {
    ws.on('timeupdate', t => { document.getElementById(`time-${d}`).textContent = formatTime(t); });
    ws.on('play',   () => { if(d==='a') stateA.playing=true; else stateB.playing=true; updatePlayBtn(d, true); });
    ws.on('pause',  () => { if(d==='a') stateA.playing=false; else stateB.playing=false; updatePlayBtn(d, false); });
    ws.on('finish', () => { if(d==='a') stateA.playing=false; else stateB.playing=false; updatePlayBtn(d, false); });
    ws.on('error',  e => {
        console.error(`WaveSurfer ERROR for DECK ${d.toUpperCase()}:`, e);
        document.getElementById(`title-${d}`).innerHTML = `<span style="color:var(--danger)">⚠️ Súbor nenájdený (${e.name || "Error"})</span>`;
    });
});

function updatePlayBtn(deck, playing) {
    document.getElementById(`btn-play-${deck}`).textContent = playing ? '⏸' : '▶';
    document.getElementById(`vinyl-icon-${deck}`).textContent = playing ? '⏸' : '▶';
}
function formatTime(s) {
    return `${Math.floor(s/60)}:${Math.floor(s%60).toString().padStart(2,'0')}`;
}

function loadTrack(deck, trackId, fromRow) {
    if (!trackId) return;
    let bpm, key, title, waveformRaw, duration;

    if (fromRow) {
        const row = document.querySelector(`.library-row[data-id="${trackId}"]`);
        if (!row) return;
        bpm = row.dataset.bpm; key = row.dataset.key; title = row.dataset.title; waveformRaw = row.dataset.waveform; duration = row.dataset.duration;
        const sel = document.getElementById(`select-track-${deck}`);
        if (sel) {
            for (let opt of sel.options) { if (opt.value === trackId) { sel.value = trackId; break; } }
        }
    } else {
        const sel = document.getElementById(`select-track-${deck}`);
        const opt = sel.options[sel.selectedIndex];
        if (!opt || !opt.value) return;
        bpm = opt.dataset.bpm; key = opt.dataset.key; title = opt.dataset.title; waveformRaw = opt.dataset.waveform; duration = opt.dataset.duration;
    }

    if (deck === 'a') { stateA.id = trackId; stateA.bpm = parseFloat(bpm); stateA.key = key; }
    else              { stateB.id = trackId; stateB.bpm = parseFloat(bpm); stateB.key = key; }

    document.getElementById(`title-${deck}`).textContent = title || 'Unknown';
    document.getElementById(`bpm-${deck}`).textContent = `${bpm} BPM`;
    document.getElementById(`key-${deck}`).textContent = key || '--';

    // Highlight active row
    document.querySelectorAll('.library-row').forEach(r => r.classList.remove(`active-${deck}`));
    const row = document.querySelector(`.library-row[data-id="${trackId}"]`);
    if (row) row.classList.add(`active-${deck}`);

    // Load audio — proxy URL
    const ws = deck === 'a' ? wavesurferA : wavesurferB;
    // Force cache busting for audio URL to avoid browser showing stale 404
    const audioUrl = `/Library/audio/${trackId}?v=${Date.now()}`;
    
    let peaks = null;
    try { if (waveformRaw && waveformRaw.length > 2) peaks = JSON.parse(waveformRaw); } catch(e) {}

    if (peaks && peaks.length > 0 && duration && parseFloat(duration) > 0) {
        ws.load(audioUrl, peaks, parseFloat(duration)); 
    } else {
        ws.load(audioUrl);
    }

    updateAiAdvice();
}

function loadFromLib(deck, trackId) { loadTrack(deck, trackId, true); }

// ── Drag & Drop ──
function handleDragStart(event, trackId) {
    event.currentTarget.classList.add('is-dragging');
    event.dataTransfer.effectAllowed = 'copy';
    event.dataTransfer.setData('trackId', trackId);
}

function handleDrop(event, deck) {
    event.preventDefault();
    const id = event.dataTransfer.getData('trackId');
    document.getElementById(`drop-zone-${deck}`)?.classList.remove(`drop-hover-${deck}`);
    if (id) loadTrack(deck, id, true);
}

// ── Playback & Controls ──
function togglePlay(deck) { (deck === 'a' ? wavesurferA : wavesurferB).playPause(); }
function updateCrossfade(val) {
    wavesurferA.setVolume((100 - val) / 100);
    wavesurferB.setVolume(val / 100);
}

// ── AI Co-Pilot ──
function updateAiAdvice() {
    const el = document.getElementById('advice-text');
    if (!stateA.id || !stateB.id) { el.innerHTML = 'Načítaj skladby do oboch deckov.'; return; }

    let msgs = [];
    if (!isNaN(stateA.bpm) && !isNaN(stateB.bpm)) {
        const diff = Math.abs(stateA.bpm - stateB.bpm).toFixed(1);
        if (diff <= 3)      msgs.push(`✅ <b>BPM OK:</b> ${stateA.bpm} vs ${stateB.bpm}`);
        else if (diff <= 8) msgs.push(`⚠️ <b>BPM ±${diff}:</b> Mierne odlišné, skús nudge.`);
        else                msgs.push(`🔴 <b>BPM CLASH ±${diff}:</b> Potrebuješ SYNC!`);
    }
    if (stateA.key && stateB.key && stateA.key !== '--' && stateB.key !== '--') {
        const nA = parseInt(stateA.key), nB = parseInt(stateB.key);
        if (stateA.key === stateB.key) msgs.push(`✨ <b>Perfektná tónina:</b> Oba v ${stateA.key}!`);
        else {
            const adj = (Math.abs(nA - nB) <= 1 || Math.abs(nA - nB) === 11) && stateA.key.slice(-1) === stateB.key.slice(-1);
            const rel = stateA.key.slice(-1) !== stateB.key.slice(-1) && nA === nB;
            if (adj || rel) msgs.push(`🟡 <b>Kompatibilná tónina:</b> ${stateA.key} → ${stateB.key} (Camelot OK).`);
            else            msgs.push(`🔴 <b>Tónina neladí:</b> ${stateA.key} vs ${stateB.key}.`);
        }
    }
    el.innerHTML = msgs.join('<br>') || 'Analyzujem...';
}

// ── Delete ──
async function deleteTrackFromMini(id, title) {
    if (!confirm(`Naozaj chceš vymazať "${title}"?`)) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    try {
        const res = await fetch(`/Library/delete/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ '__RequestVerificationToken': token })
        });
        if (res.ok) {
            const row = document.getElementById(`lib-row-${id}`);
            if (row) {
                row.style.transition = 'opacity 0.3s, transform 0.3s';
                row.style.opacity = '0';
                row.style.transform = 'translateX(-20px)';
                setTimeout(() => row.remove(), 300);
            }
        } else alert('Vymazanie zlyhalo.');
    } catch(e) { alert('Chyba: ' + e.message); }
}

// ── Render Mix ──
async function renderMix() {
    if (!stateA.id || !stateB.id) {
        document.getElementById('advice-text').innerHTML = '⚠️ Zvoľ skladby pre oba decky!'; return;
    }
    const btn = document.getElementById('render-btn');
    const btnText = document.getElementById('render-btn-text');
    const resultDiv = document.getElementById('render-result');
    btn.disabled = true;
    btnText.innerHTML = '⏳ Generujem mix... (~60 sek)';
    resultDiv.style.display = 'none';

    try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const fd = new FormData();
        fd.append('trackAId', stateA.id);
        fd.append('trackBId', stateB.id);
        fd.append('__RequestVerificationToken', token);

        const response = await fetch('/Home/RenderMix', { method: 'POST', body: fd });
        if (!response.ok) throw new Error((await response.text()).substring(0, 200));

        const blob = await response.blob();
        const url = URL.createObjectURL(blob);
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `
            <div class="render-success">
                ✅ Mix hotový!
                <audio controls src="${url}" class="render-audio"></audio>
                <a href="${url}" download="mixerai-mix.mp3">⬇ Stiahnuť MP3</a>
            </div>`;
    } catch(e) {
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `<div class="render-error">❌ ${e.message}</div>`;
    } finally {
        btn.disabled = false;
        btnText.innerHTML = '⚡ GENERATE MIX';
    }
}
</script>
@Html.AntiForgeryToken()
}
