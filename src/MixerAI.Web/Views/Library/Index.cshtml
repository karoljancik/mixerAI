@model List<MixerAI.Web.Models.TrackViewModel>
@{
    ViewData["Title"] = "Library";
}

<div class="lib-page">
    <div class="lib-hero">
        <span class="eyebrow">Library Control</span>
        <h1>Your track library</h1>
        <p>Upload source tracks, monitor AI analysis health, and requeue failed analysis runs without leaving the workflow.</p>
    </div>

    <div class="lib-upload-bar">
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="lib-upload-form">
            <label class="lib-upload-btn" for="trackUpload">
                + Upload track
            </label>
            <input type="file" id="trackUpload" name="file" class="d-none"
                   accept=".mp3,.wav,.flac,.mp4,.m4a,.ogg"
                   onchange="this.form.submit()" />
            <span class="lib-upload-hint">MP3 · WAV · FLAC · MP4 · M4A</span>
        </form>
        <a href="/" class="lib-studio-btn">Open Workspace</a>
    </div>

    <div class="lib-table-panel">
        <table class="lib-full-table">
            <thead>
                <tr>
                    <th style="width:110px">Status</th>
                    <th>Title</th>
                    <th style="width:80px">BPM</th>
                    <th style="width:60px">Key</th>
                    <th style="width:70px">Length</th>
                    <th style="width:70px">Attempts</th>
                    <th style="width:140px">Added</th>
                    <th style="width:140px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var track in Model)
                {
                    var isError = string.Equals(track.Status, "Error", StringComparison.OrdinalIgnoreCase);
                    <tr id="row-@track.Id">
                        <td>
                            @if (string.Equals(track.Status, "Ready", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge-ready">Ready</span>
                            }
                            else if (string.Equals(track.Status, "Analyzing", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge-analyzing">
                                    <span class="spinner-dot"></span> Analyzing
                                </span>
                            }
                            else if (isError)
                            {
                                <span class="badge-error">Error</span>
                            }
                            else
                            {
                                <span class="badge-pending">Queued</span>
                            }
                        </td>
                        <td class="lib-track-title">
                            <div>@track.Title</div>
                            @if (isError && !string.IsNullOrWhiteSpace(track.LastAnalysisError))
                            {
                                <div class="track-inline-error">@track.LastAnalysisError</div>
                            }
                        </td>
                        <td class="lib-bpm-cell">@(track.BPM?.ToString("0.0") ?? "--")</td>
                        <td>
                            @if (track.CamelotKey != null)
                            {
                                <span class="camelot-chip">@track.CamelotKey</span>
                            }
                            else
                            {
                                <span class="text-muted">--</span>
                            }
                        </td>
                        <td class="lib-dur-cell">@(track.DurationSeconds > 0 ? TimeSpan.FromSeconds(track.DurationSeconds).ToString(@"mm\:ss") : "--")</td>
                        <td class="lib-date-cell">@track.AnalysisAttempts</td>
                        <td class="lib-date-cell">@track.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                        <td>
                            <div class="library-actions">
                                @if (isError)
                                {
                                    <button type="button" class="mini-action-btn" onclick="retryTrack('@track.Id', '@track.Title')">Retry</button>
                                }
                                <button type="button" class="lib-delete-btn" onclick="deleteTrack('@track.Id', '@track.Title')" title="Delete">&#128465;</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="lib-empty-row">
                            No tracks yet. Upload your first source file and start building your AI-ready library.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
async function deleteTrack(id, title) {
    if (!confirm(`Delete "${title}"?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    try {
        const res = await fetch(`/Library/delete/${id}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token,
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ '__RequestVerificationToken': token }),
        });
        if (res.ok) {
            const row = document.getElementById(`row-${id}`);
            row.style.transition = 'opacity 0.3s';
            row.style.opacity = '0';
            setTimeout(() => row.remove(), 300);
        } else {
            alert('Delete failed. Try again.');
        }
    } catch (error) {
        alert('Delete failed: ' + error.message);
    }
}

async function retryTrack(id, title) {
    if (!confirm(`Retry analysis for "${title}"?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    try {
        const res = await fetch(`/Library/retry/${id}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token,
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ '__RequestVerificationToken': token }),
        });

        if (!res.ok) {
            alert('Retry failed. Try again.');
            return;
        }

        window.location.reload();
    } catch (error) {
        alert('Retry failed: ' + error.message);
    }
}
</script>
@Html.AntiForgeryToken()
}
